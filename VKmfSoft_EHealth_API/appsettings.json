{

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  "ConnectionStrings": {
    "DefaultSQLConnection": "Data Source=KOENI7;Initial Catalog=EHealth;Integrated Security=True;TrustServerCertificate=True;"
  },
  "AutoMapper": {
    "LicenseKey": "your_license_key_here"
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": "Information",
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "log/SchoolManagement.log",
          "rollingInterval": "Day"
        }
      }
    ]

  }

} 